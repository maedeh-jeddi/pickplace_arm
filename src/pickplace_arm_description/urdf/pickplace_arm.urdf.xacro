<?xml version="1.0"?>
<robot name="pickplace_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- When true, pull in the Gazebo Harmonic ros2_control system + sensors.
       Left false for the MoveIt/mock-hardware description so we don't end up
       with two ros2_control systems. gazebo.launch.py sets this to true. -->
  <xacro:arg name="use_gazebo" default="false"/>

  <!-- base_link is the free-floating root: a mobile base (see wheels below)
       carries it, rather than a fixed bolt to a "world" frame. -->

  <!-- ============ Properties ============ -->
  <xacro:property name="PI" value="3.14159265359"/>

  <!-- Chassis is a box sized proportional to the wheelbase (wheels sit at
       x=+/-0.12, y=+/-0.15). base_link origin is at wheel-axle height
       (spawned at world z=0.05); box height 0.08 centered there spans world
       z 0.01..0.09 so it clears the ground, and the arm still mounts on the
       top face at z = base_height/2. base_radius is retained only as a
       representative value for the inertia macro. -->
  <xacro:property name="base_radius" value="0.13"/>
  <xacro:property name="base_height" value="0.08"/>
  <xacro:property name="base_length" value="0.38"/>
  <xacro:property name="base_width" value="0.26"/>

  <!-- ============ Mobile base (4-wheel skid-steer) ============
       base_link is spawned at world z=0.05 (see gazebo.launch.py), which is
       unchanged by adding the base - wheel_radius is chosen to exactly
       match that spawn height so the wheels touch the ground plane, and
       every existing ground/grasp-height constant elsewhere in the repo
       (pick_and_place.py, add_collision_box, etc.) stays valid untouched. -->
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.03"/>
  <xacro:property name="wheel_x_offset" value="0.12"/>
  <xacro:property name="wheel_y_offset" value="0.15"/>

  <!-- Arm link lengths trimmed 30% from the original (0.15/0.30/0.25/0.10/
       0.08/0.06) for a more compact reach (~0.66m total vs ~0.94m before).
       Radii are also tapered link-to-link (thicker at the shoulder, thinner
       at the wrist) for a cleaner, more proportioned silhouette instead of
       uniform-thickness segments; this and the joint-cap spheres below
       are the "nicer looking" visual pass, built entirely from primitives
       since no mesh-authoring tool (e.g. Blender) is available. -->
  <xacro:property name="link1_len" value="0.105"/>
  <xacro:property name="link2_len" value="0.21"/>
  <xacro:property name="link3_len" value="0.175"/>
  <xacro:property name="link4_len" value="0.07"/>
  <xacro:property name="link5_len" value="0.056"/>
  <xacro:property name="link6_len" value="0.042"/>

  <!-- Lateral (forward, +x) offsets that break the arm out of a single
       straight line, like real industrial arms (e.g. the UR series'
       shoulder/wrist offsets). shoulder_offset kinks the upper arm forward
       of the vertical base-yaw column; wrist_offset steps the wrist cluster
       forward of the forearm. This avoids the fully-collinear home pose the
       arm had before (which sat right on top of joint-axis alignments) and
       gives cleaner IK conditioning near full extension. The J4-J5-J6 wrist
       cluster itself is left un-offset so it stays a clean spherical wrist
       for orientation control. Values re-verified reachable via compute_ik. -->
  <xacro:property name="shoulder_offset" value="0.035"/>
  <xacro:property name="wrist_offset" value="0.030"/>

  <xacro:property name="link_radius" value="0.030"/>
  <xacro:property name="link2_radius" value="0.032"/>
  <xacro:property name="link3_radius" value="0.028"/>
  <xacro:property name="link4_radius" value="0.026"/>
  <xacro:property name="link5_radius" value="0.022"/>
  <xacro:property name="link6_radius" value="0.022"/>

  <!-- Joint-cap sphere radii (visual only, not collision; see each joint
       below): slightly larger than the thicker of the two links they join,
       so each pivot reads as a distinct actuator housing. -->
  <xacro:property name="cap1_radius" value="0.045"/>
  <xacro:property name="cap2_radius" value="0.040"/>
  <xacro:property name="cap3_radius" value="0.035"/>
  <xacro:property name="cap4_radius" value="0.032"/>
  <xacro:property name="cap5_radius" value="0.028"/>
  <xacro:property name="cap6_radius" value="0.026"/>

  <!-- Materials -->
  <material name="arm_orange"><color rgba="0.9 0.45 0.1 1.0"/></material>
  <material name="arm_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
  <material name="arm_grey"><color rgba="0.6 0.6 0.6 1.0"/></material>

  <!-- ============ Inertial Macro ============ -->
  <xacro:macro name="cylinder_inertial" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass*(3*radius*radius+length*length)/12}" ixy="0.0" ixz="0.0"
        iyy="${mass*(3*radius*radius+length*length)/12}" iyz="0.0"
        izz="${mass*radius*radius/2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass*(y*y+z*z)/12}" ixy="0.0" ixz="0.0"
        iyy="${mass*(x*x+z*z)/12}" iyz="0.0"
        izz="${mass*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- ============ Base Link (box chassis, proportional to wheels) =======
       base_link is the kinematic ROOT (as it was before the mobile base was
       added), so MoveIt's world->base_link virtual joint and Cartesian path
       planning work exactly as verified. base_footprint (Nav2's ground
       projection frame) hangs off it as a CHILD below, rather than being the
       root; making base_footprint the root broke MoveIt's planning tree
       ("base_link and base_footprint not part of the same tree"). -->
  <link name="base_link">
    <visual>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <collision>
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <xacro:box_inertial mass="2.0" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <!-- Nav2 ground-projection frame, as a child of base_link (base_link sits
       one wheel-radius above the ground, so base_footprint is that far
       below). -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 ${-wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ============ Wheels (4-wheel skid-steer diff drive) ============
       Cylinder axis rotated onto Y so wheels roll about the Y axis (forward
       motion along X), matching the continuous joint axis "0 1 0" below. -->
  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="arm_dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cylinder_inertial mass="0.3" radius="${wheel_radius}" length="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${x_reflect*wheel_x_offset} ${y_reflect*wheel_y_offset} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="front_left"  x_reflect="1"  y_reflect="1"/>
  <xacro:wheel prefix="front_right" x_reflect="1"  y_reflect="-1"/>
  <xacro:wheel prefix="rear_left"   x_reflect="-1" y_reflect="1"/>
  <xacro:wheel prefix="rear_right"  x_reflect="-1" y_reflect="-1"/>

  <!-- ============ 2D LIDAR (chassis-mounted, for SLAM/Nav2) ============
       Mounted at the front edge of the chassis, ahead of both the
       centrally-mounted arm (base at x=0) and the wrist RGB camera it
       carries, so neither sits in the sensor's forward view. The scan
       itself is restricted to a 270 deg forward arc in the Gazebo sensor
       config (see pickplace_arm.gazebo.xacro) so the excluded 90 deg wedge
       falls directly behind the sensor, exactly where the arm is,
       instead of scanning through it. -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.03" length="0.04"/></geometry>
      <material name="arm_grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.03" length="0.04"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.1" radius="0.03" length="0.04"/>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- inset from the front edge (chassis half-length 0.19, lidar radius
         0.03 -> 0.02 m clearance) and mounted flush on the chassis top face
         (top face at base_height/2=0.04, lidar half-length 0.02) so it sits
         on the surface instead of floating above it. -->
    <origin xyz="0.14 0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- IMU: its yaw is fused with the wheel odometry (robot_localization EKF)
       to stabilize heading, which the 4-wheel skid-steer's wheel-only odom
       estimates poorly (lateral scrub during turns causes heading drift that
       corrupts SLAM). Mounted at the chassis center. -->
  <link name="imu_link">
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <!-- Front-facing RGB-D camera mounted flush on the CHASSIS FRONT FACE
       (the +x face is at base_length/2 = 0.19; the camera body is 0.03 deep so
       its center sits at 0.19 + 0.015 = 0.205), near the top of the face and
       centred in y. Pitched ~11 deg down so its frustum sweeps the ground
       ahead for box detection while the base drives. -->
  <link name="front_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.06 0.03"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.06 0.03"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.05" radius="0.02" length="0.03"/>
  </link>

  <joint name="front_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_camera_link"/>
    <origin xyz="0.205 0 0.03" rpy="0 0.20 0"/>
  </joint>

  <link name="front_camera_optical_link"/>
  <joint name="front_camera_optical_joint" type="fixed">
    <parent link="front_camera_link"/>
    <child link="front_camera_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ============ Link 1 (Shoulder Yaw) ============ -->
  <link name="link1">
    <visual>
      <!-- shoulder joint-cap: visual only, sits over joint1's pivot -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${cap1_radius}"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link1_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link_radius}" length="${link1_len}"/></geometry>
      <material name="arm_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link1_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link_radius}" length="${link1_len}"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="1.0" radius="${link_radius}" length="${link1_len}"/>
  </link>

  <!-- Roll joint with +/-2pi range (not +/-pi): a target near one pi limit can
       then be reached from near the other via its +/-2pi equivalent (same
       orientation) instead of unwinding ~2pi. Still bounded revolute, so no
       continuous-joint state aliasing. -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${2*PI}" upper="${2*PI}" effort="50" velocity="1.5"/>
  </joint>

  <!-- ============ Link 2 (Upper Arm Pitch) ============ -->
  <link name="link2">
    <visual>
      <!-- elbow-shoulder joint-cap: visual only, sits over joint2's pivot -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${cap2_radius}"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link2_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link2_radius}" length="${link2_len}"/></geometry>
      <material name="arm_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link2_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link2_radius}" length="${link2_len}"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="1.2" radius="${link2_radius}" length="${link2_len}"/>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <!-- shoulder offset: upper arm steps forward of the base-yaw column -->
    <origin xyz="${shoulder_offset} 0 ${link1_len}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${PI/2}" upper="${PI/2}" effort="50" velocity="1.5"/>
  </joint>

  <!-- ============ Link 3 (Forearm Pitch) ============ -->
  <link name="link3">
    <visual>
      <!-- elbow joint-cap: visual only, sits over joint3's pivot -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${cap3_radius}"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link3_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link3_radius}" length="${link3_len}"/></geometry>
      <material name="arm_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link3_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link3_radius}" length="${link3_len}"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.8" radius="${link3_radius}" length="${link3_len}"/>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 ${link2_len}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${PI*0.75}" upper="${PI*0.75}" effort="40" velocity="1.5"/>
  </joint>

  <!-- ============ Link 4 (Wrist Roll) ============ -->
  <link name="link4">
    <visual>
      <!-- forearm-wrist joint-cap: visual only, sits over joint4's pivot -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${cap4_radius}"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link4_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link4_radius}" length="${link4_len}"/></geometry>
      <material name="arm_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link4_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link4_radius}" length="${link4_len}"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.4" radius="${link4_radius}" length="${link4_len}"/>
  </link>

  <!-- Forearm roll with +/-2pi range so the gripper-down grasp (j4 ~= +/-pi) is
       reachable from either side without a ~2pi unwind. -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <!-- wrist offset: wrist cluster steps forward of the forearm -->
    <origin xyz="${wrist_offset} 0 ${link3_len}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${2*PI}" upper="${2*PI}" effort="20" velocity="2.0"/>
  </joint>

  <!-- ============ Link 5 (Wrist Pitch) ============ -->
  <link name="link5">
    <visual>
      <!-- wrist joint-cap: visual only, sits over joint5's pivot -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${cap5_radius}"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link5_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link5_radius}" length="${link5_len}"/></geometry>
      <material name="arm_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link5_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link5_radius}" length="${link5_len}"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.3" radius="${link5_radius}" length="${link5_len}"/>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 ${link4_len}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${PI/2}" upper="${PI/2}" effort="15" velocity="2.0"/>
  </joint>

  <!-- ============ Link 6 (Tool Flange / Wrist Roll) ============ -->
  <link name="link6">
    <visual>
      <!-- flange joint-cap: visual only, sits over joint6's pivot -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${cap6_radius}"/></geometry>
      <material name="arm_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link6_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link6_radius}" length="${link6_len}"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${link6_len/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${link6_radius}" length="${link6_len}"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.2" radius="${link6_radius}" length="${link6_len}"/>
  </link>

  <!-- Wrist roll with +/-2pi range, same reason as j4. -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 ${link5_len}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-${2*PI}" upper="${2*PI}" effort="10" velocity="2.0"/>
  </joint>

  <!-- ============ Gripper (simple 2-finger, mounted on link6) ============ -->
  <link name="gripper_base">
    <visual>
      <geometry><box size="0.06 0.08 0.03"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <collision>
      <geometry><box size="0.06 0.08 0.03"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.15" radius="0.03" length="0.03"/>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="link6"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 ${link6_len}" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="finger" params="prefix reflect">
    <link name="${prefix}_finger">
      <visual>
        <geometry><box size="0.015 0.02 0.06"/></geometry>
        <material name="arm_grey"/>
      </visual>
      <collision>
        <geometry><box size="0.015 0.02 0.06"/></geometry>
      </collision>
      <xacro:cylinder_inertial mass="0.05" radius="0.01" length="0.06"/>
    </link>

    <joint name="${prefix}_finger_joint" type="prismatic">
      <parent link="gripper_base"/>
      <child link="${prefix}_finger"/>
      <origin xyz="0 ${reflect*0.03} 0.045" rpy="0 0 0"/>
      <!-- Mirror the axis per side so both fingers move outward together:
           position 0 = closed (jaw gap 0.04 m), position 0.03 = open (gap 0.10 m) -->
      <axis xyz="0 ${reflect} 0"/>
      <limit lower="0.0" upper="0.03" effort="20" velocity="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:finger prefix="left" reflect="1"/>
  <xacro:finger prefix="right" reflect="-1"/>

  <!-- ============ RGB-D Camera (mounted on gripper_base) ============ -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.02"/></geometry>
      <material name="arm_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.02"/></geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.05" radius="0.015" length="0.02"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="camera_link"/>
    <origin xyz="0.04 0 0.02" rpy="0 0.5 0"/>
  </joint>

  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ============ Gazebo Harmonic integration (only when simulating) ============ -->
  <xacro:if value="$(arg use_gazebo)">
    <xacro:include filename="$(find pickplace_arm_description)/urdf/pickplace_arm.gazebo.xacro"/>
  </xacro:if>

</robot>
