<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ros2_control system for Gazebo Harmonic -->
  <ros2_control name="pickplace_arm_system" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- initial_value makes the arm SPAWN in the gripper-DOWN "claw ready" pose
         (matches HOME_CONFIG in pick_and_place.py): j1 0, j2 0.52, j3 1.14,
         j4 -3.14, j5 -1.48, j6 0. The gripper points straight down, reaching
         ~0.38 m ahead, so it can descend straight onto a box driven under it. -->
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.52</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">1.14</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">-3.14</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint5">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">-1.48</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo Harmonic gz_ros2_control plugin -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find pickplace_arm_description)/config/arm_controllers.yaml</parameters>
      <ros>
        <remapping>~/robot_description:=/robot_description</remapping>
      </ros>
    </plugin>
  </gazebo>

  <!-- High friction + soft contact on the finger pads so the gripper can
       actually hold a box by friction in Gazebo Harmonic. -->
  <gazebo reference="left_finger">
    <mu1>3.5</mu1>
    <mu2>3.5</mu2>
    <kp>1e6</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
  </gazebo>
  <gazebo reference="right_finger">
    <mu1>3.5</mu1>
    <mu2>3.5</mu2>
    <kp>1e6</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.0</maxVel>
  </gazebo>

  <!-- Wheel ground contact friction, enough traction to drive/skid-steer
       without excessive slip. -->
  <xacro:macro name="wheel_friction" params="link">
    <gazebo reference="${link}">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <kp>1e6</kp>
      <kd>1.0</kd>
      <minDepth>0.001</minDepth>
    </gazebo>
  </xacro:macro>
  <xacro:wheel_friction link="front_left_wheel"/>
  <xacro:wheel_friction link="front_right_wheel"/>
  <xacro:wheel_friction link="rear_left_wheel"/>
  <xacro:wheel_friction link="rear_right_wheel"/>

  <!-- RGB-D Camera sensor (Gazebo Harmonic) -->
  <gazebo reference="camera_link">
    <sensor name="rgbd_camera" type="rgbd_camera">
      <topic>/camera</topic>
      <update_rate>30</update_rate>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>5.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <gz_frame_id>camera_optical_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- 2D LIDAR sensor (Gazebo Harmonic gpu_lidar) for SLAM + Nav2 -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <topic>/scan</topic>
      <update_rate>10</update_rate>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <lidar>
        <scan>
          <!-- 270 deg forward arc (-135..+135 deg); the excluded 90 deg
               wedge points straight back at the arm, so the scan never hits
               it. 270 samples keeps the same ~1 deg/sample resolution as a
               360-sample full circle. -->
          <horizontal>
            <samples>270</samples>
            <resolution>1</resolution>
            <min_angle>-2.35619449</min_angle>
            <max_angle>2.35619449</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- IMU sensor: publishes orientation + angular velocity, fused with wheel
       odometry by the robot_localization EKF to keep heading accurate. -->
  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <topic>/imu</topic>
      <update_rate>50</update_rate>
      <always_on>1</always_on>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Front RGB-D camera: detects the box ahead while the base drives. -->
  <gazebo reference="front_camera_link">
    <sensor name="front_rgbd_camera" type="rgbd_camera">
      <topic>/front_camera</topic>
      <update_rate>30</update_rate>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <camera>
        <!-- Wide 90 deg FOV so the box stays in view even when Nav2 leaves the
             base a little off-heading, so the front-cam approach never has to
             rotate the chassis to re-acquire it (no spin before arriving). -->
        <horizontal_fov>1.57</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <gz_frame_id>front_camera_optical_link</gz_frame_id>
    </sensor>
  </gazebo>

</robot>
